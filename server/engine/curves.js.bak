/**
 * Curve Primitives — Pure mathematical functions
 * All functions: (t: number) => number
 * Deterministic, no side effects
 */

/**
 * Exponential spike: rapid rise then exponential decay
 * Models acute substance effects (caffeine, nicotine spikes)
 * @param {number} peak - Maximum value (0-1)
 * @param {number} delay - Onset time (minutes from t=0)
 * @param {number} decay - Decay constant (larger = slower decay)
 * @returns {Function} curve function (t) => value
 */
function spike(peak, delay, decay) {
  return (t) => {
    const x = t - delay;
    if (x < 0) return 0;
    return peak * Math.exp(-x / decay);
  };
}

/**
 * Linear ramp: gradual rise to plateau, then slow decay
 * Models slower metabolic responses (glucose, meal effects)
 * @param {number} peak - Maximum value
 * @param {number} riseTime - Time to reach peak
 * @param {number} plateuTime - Duration at peak level
 * @param {number} fallTime - Decay duration
 * @returns {Function} curve function
 */
function ramp(peak, riseTime, plateuTime, fallTime) {
  return (t) => {
    if (t < 0) return 0;
    if (t < riseTime) return (peak / riseTime) * t;
    if (t < riseTime + plateuTime) return peak;

    const fallProgress = (t - riseTime - plateuTime) / fallTime;
    if (fallProgress >= 1) return 0;
    return peak * (1 - fallProgress);
  };
}

/**
 * Exponential decay from initial value
 * Models sustained effects (persistent cortisol, dopamine tolerance)
 * @param {number} initial - Starting value
 * @param {number} decay - Decay constant
 * @returns {Function} curve function
 */
function decay(initial, decay) {
  return (t) => {
    if (t < 0) return initial;
    return initial * Math.exp(-t / decay);
  };
}

/**
 * Clamp value to [0, 1] range
 * @param {number} v - Value
 * @returns {number} Clamped value
 */
function clamp(v) {
  return Math.max(0, Math.min(1, v));
}

module.exports = {
  spike,
  ramp,
  decay,
  clamp,
};
