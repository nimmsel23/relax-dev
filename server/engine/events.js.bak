/**
 * Event Effects — Define how different events affect cortisol, dopamine, glucose
 * Each event returns curve functions for each hormone
 */

import { spike, ramp, clamp } from "./curves.js";

/**
 * Coffee/Caffeine effect
 * @param {number} dose - 1-10 scale
 * @param {number} time - Event time (minutes)
 * @returns {Object} {cortisol, dopamine, glucose} curve functions
 */
function coffeeEffect(dose, time) {
  const doseFactor = Math.min(dose, 10) / 10;

  return {
    cortisol: spike(0.3 * doseFactor, time + 10, 90),
    dopamine: spike(0.25 * doseFactor, time + 15, 120),
    glucose: spike(0.15 * doseFactor, time + 20, 60),
  };
}

/**
 * Nicotine effect
 * @param {number} dose - 1-10 scale
 * @param {number} time - Event time
 * @returns {Object} {cortisol, dopamine, glucose} curves
 */
function nicotineEffect(dose, time) {
  const doseFactor = Math.min(dose, 10) / 10;

  return {
    cortisol: spike(0.2 * doseFactor, time + 5, 45),
    dopamine: spike(0.4 * doseFactor, time + 8, 90), // Strong dopamine hit
    glucose: spike(0.1 * doseFactor, time + 10, 40),
  };
}

/**
 * THC effect (cannabis)
 * @param {string} strength - "low" | "high"
 * @param {number} time - Event time
 * @returns {Object} {cortisol, dopamine, glucose} curves
 */
function thcEffect(strength, time) {
  const factor = strength === "high" ? 1.0 : 0.5;

  return {
    // THC increases cortisol initially (stress response), then drops
    cortisol: spike(0.25 * factor, time + 15, 180),
    // THC causes dopamine volatility (unpredictable pattern)
    dopamine: spike(0.35 * factor, time + 20, 150),
    // THC can affect glucose (increased appetite)
    glucose: spike(0.2 * factor, time + 30, 120),
  };
}

/**
 * Meal effect
 * @param {string} macro - "carbs" | "protein" | "fat"
 * @param {number} time - Event time
 * @returns {Object} {cortisol, dopamine, glucose} curves
 */
function mealEffect(macro, time) {
  let glucoseFactor, dopamineFactor;

  switch (macro) {
    case "carbs":
      glucoseFactor = 0.6; // High glucose spike
      dopamineFactor = 0.15;
      break;
    case "protein":
      glucoseFactor = 0.3;
      dopamineFactor = 0.25; // Amino acids boost dopamine
      break;
    case "fat":
      glucoseFactor = 0.15;
      dopamineFactor = 0.2;
      break;
    default:
      glucoseFactor = 0.3;
      dopamineFactor = 0.15;
  }

  return {
    cortisol: spike(0.1, time + 30, 120), // Mild cortisol spike from digestion
    dopamine: spike(dopamineFactor, time + 40, 180),
    glucose: ramp(glucoseFactor, 20, 60, 120),
  };
}

/**
 * Get effect curves for a single event
 * @param {Object} event - {type, time, dose/strength/macro}
 * @returns {Object} Effect curves or null if unknown type
 */
function getEventEffect(event) {
  const { type, time, dose, strength, macro } = event;

  switch (type) {
    case "coffee":
      return coffeeEffect(dose || 1, time);
    case "nicotine":
      return nicotineEffect(dose || 1, time);
    case "thc":
      return thcEffect(strength || "low", time);
    case "meal":
      return mealEffect(macro || "carbs", time);
    default:
      return null;
  }
}

module.exports = {
  coffeeEffect,
  nicotineEffect,
  thcEffect,
  mealEffect,
  getEventEffect,
};
