import { usePhysioStore } from '../../store/physioStore'

export default function EventInputPanel() {
  const addEvent = usePhysioStore((s) => s.addEvent)
  const events = usePhysioStore((s) => s.events)

  const handleAddEvent = (type, dose = 1, macro = 'carbs') => {
    // Default time: next event at last event time + 120 min (or 0 if first)
    const defaultTime = events.length > 0
      ? Math.max(...events.map(e => e.time || 0)) + 120
      : 0

    addEvent({
      type,
      time: defaultTime,
      ...(type === 'coffee' || type === 'nicotine' ? { dose } : {}),
      ...(type === 'meal' ? { macro } : {}),
      ...(type === 'thc' ? { strength: 'low' } : {}),
    })
  }

  return (
    <div className="bg-card rounded-lg p-4 mb-4 border border-line">
      <h3 className="text-sm font-semibold mb-3" style={{ color: 'var(--ink)' }}>
        Add Event
      </h3>

      <div className="grid grid-cols-2 gap-2">
        <button
          onClick={() => handleAddEvent('coffee', 2)}
          className="px-3 py-2 text-xs font-semibold rounded-lg transition-colors"
          style={{ background: 'var(--accent)', color: 'white' }}
        >
          ☕ Coffee
        </button>

        <button
          onClick={() => handleAddEvent('meal', undefined, 'carbs')}
          className="px-3 py-2 text-xs font-semibold rounded-lg transition-colors"
          style={{ background: 'var(--accent)', color: 'white' }}
        >
          🍽️ Meal
        </button>

        <button
          onClick={() => handleAddEvent('nicotine', 1)}
          className="px-3 py-2 text-xs font-semibold rounded-lg transition-colors"
          style={{ background: 'var(--accent)', color: 'white' }}
        >
          🚬 Nicotine
        </button>

        <button
          onClick={() => handleAddEvent('thc', undefined)}
          className="px-3 py-2 text-xs font-semibold rounded-lg transition-colors"
          style={{ background: 'var(--accent)', color: 'white' }}
        >
          🌿 THC
        </button>
      </div>
    </div>
  )
}
