@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --bg:         #080b12;
  --bg2:        #0c1019;
  --panel:      #111827;
  --card:       #151d2e;
  --card-hover: #1a2439;
  --line:       #1e2d44;
  --ink:        #eef1f8;
  --muted:      #7b8ba5;
  --dim:        #4a5874;
  --accent:     #5eead4;
  --accent-glow: rgba(94,234,212,0.12);
  --green:      #22c55e;
  --red:        #ef4444;
  --orange:     #f97316;
  --glass:      rgba(17,24,39,0.85);
  --glass-border: rgba(94,234,212,0.08);
}

[data-theme="latte"] {
  --bg:         #f5f0e8;
  --bg2:        #ebe5db;
  --panel:      #e2dbd0;
  --card:       #f0ebe3;
  --card-hover: #e8e2d8;
  --line:       #cdc4b6;
  --ink:        #1e1c19;
  --muted:      #6b6356;
  --dim:        #9a9080;
  --accent:     #0e7a73;
  --accent-glow: rgba(14,122,115,0.08);
  --green:      #16a34a;
  --red:        #dc2626;
  --orange:     #ea580c;
  --glass:      rgba(226,219,208,0.85);
  --glass-border: rgba(14,122,115,0.1);
}

*, *::before, *::after { box-sizing: border-box; }

html { height: 100%; -webkit-tap-highlight-color: transparent; }

body {
  font-family: "Inter", system-ui, -apple-system, sans-serif;
  font-size: 14px;
  line-height: 1.55;
  background: var(--bg);
  color: var(--ink);
  height: 100%;
  overflow: hidden;
  margin: 0;
  padding: 0;
}

#root {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--line); border-radius: 2px; }

/* spinner */
@keyframes spin { to { transform: rotate(360deg); } }
.spinner {
  width: 14px; height: 14px;
  border: 2px solid var(--line);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: inline-block;
}
