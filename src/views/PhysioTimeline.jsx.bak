import EventInputPanel from '../components/physio/EventInputPanel'
import EventList from '../components/physio/EventList'
import SimulationControls from '../components/physio/SimulationControls'
import PhysioChart from '../components/physio/PhysioChart'
import { usePhysioStore } from '../store/physioStore'
import { Zap } from 'lucide-react'

export default function PhysioTimeline() {
  const error = usePhysioStore((s) => s.error)
  const isLoading = usePhysioStore((s) => s.isLoading)
  const clearEvents = usePhysioStore((s) => s.clearEvents)
  const clearSimulationResult = usePhysioStore((s) => s.clearSimulationResult)

  const handleReset = () => {
    clearEvents()
    clearSimulationResult()
  }

  return (
    <div className="flex flex-col h-full">
      {/* Header */}
      <div className="border-b p-4 flex items-start justify-between shrink-0" style={{ borderColor: 'var(--line)' }}>
        <div>
          <div className="flex items-center gap-2 mb-1">
            <Zap size={24} style={{ color: 'var(--accent)' }} />
            <h1 className="text-2xl font-bold" style={{ color: 'var(--ink)' }}>
              Physio Timeline
            </h1>
          </div>
          <p className="text-xs" style={{ color: 'var(--muted)' }}>
            Simulate how your lifestyle choices affect cortisol, dopamine & glucose
          </p>
        </div>
        <button
          onClick={handleReset}
          className="px-3 py-2 text-xs font-semibold rounded-lg border transition-all hover:opacity-80 whitespace-nowrap ml-4"
          style={{
            background: 'var(--card)',
            borderColor: 'var(--line)',
            color: 'var(--muted)'
          }}
        >
          ↻ Reset All
        </button>
      </div>

      {/* Error Alert */}
      {error && (
        <div
          className="mx-4 mt-4 p-3 rounded-lg border-l-4 animate-pulse"
          style={{ background: 'rgba(255, 107, 107, 0.08)', borderLeftColor: '#ff6b6b' }}
        >
          <p className="text-sm font-semibold" style={{ color: '#ff6b6b' }}>
            ⚠️ {error}
          </p>
        </div>
      )}

      {/* Loading State */}
      {isLoading && (
        <div
          className="mx-4 mt-4 p-3 rounded-lg text-center text-sm font-semibold"
          style={{ background: 'var(--glass)', color: 'var(--accent)' }}
        >
          🧬 Computing physiological response...
        </div>
      )}

      {/* Main Layout: Left Sidebar + Wide Chart */}
      <div className="flex flex-1 gap-3 p-3 overflow-hidden">
        {/* LEFT: Events & Controls (Sidebar) */}
        <div className="w-80 overflow-y-auto space-y-4 flex-shrink-0">
          <EventInputPanel />
          <EventList />
          <SimulationControls />
        </div>

        {/* RIGHT: Chart (Wide) */}
        <div className="flex-1 flex flex-col gap-3 overflow-hidden">
          {/* Chart Card - Takes Full Space */}
          <div
            className="flex-1 rounded-lg border p-3 overflow-hidden flex flex-col"
            style={{ background: 'var(--card)', borderColor: 'var(--line)' }}
          >
            <h3 className="text-xs font-semibold mb-2" style={{ color: 'var(--ink)' }}>
              📈 Physiological Response
            </h3>
            <div className="flex-1 overflow-hidden">
              <PhysioChart />
            </div>
          </div>

          {/* Info + Color Guide (Bottom) */}
          <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
            {/* Color Guide */}
            <div
              className="p-3 rounded-lg border"
              style={{ background: 'var(--card)', borderColor: 'var(--line)' }}
            >
              <p className="text-xs font-semibold mb-2" style={{ color: 'var(--ink)' }}>
                📊 Legend:
              </p>
              <div className="space-y-1 text-xs">
                <div className="flex items-center gap-2">
                  <div className="w-2 h-2 rounded-full" style={{ background: '#ff6b6b' }}></div>
                  <span style={{ color: 'var(--muted)' }}>Cortisol (stress)</span>
                </div>
                <div className="flex items-center gap-2">
                  <div className="w-2 h-2 rounded-full" style={{ background: '#4ecdc4' }}></div>
                  <span style={{ color: 'var(--muted)' }}>Dopamine (motivation)</span>
                </div>
                <div className="flex items-center gap-2">
                  <div className="w-2 h-2 rounded-full" style={{ background: '#ffd93d' }}></div>
                  <span style={{ color: 'var(--muted)' }}>Glucose (energy)</span>
                </div>
              </div>
            </div>

            {/* Quick Tips */}
            <div
              className="p-3 rounded-lg border"
              style={{ background: 'var(--glass)', borderColor: 'var(--line)' }}
            >
              <p className="text-xs font-semibold mb-2" style={{ color: 'var(--ink)' }}>
                💡 Tips:
              </p>
              <ul className="text-xs space-y-1" style={{ color: 'var(--muted)' }}>
                <li>• Timing matters: spacing events reduces interference</li>
                <li>• Synergies: caffeine + L-theanine = calm focus</li>
                <li>• Context: fasting increases glucose volatility</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  )
}
